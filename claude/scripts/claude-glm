#!/usr/bin/env bash
# Claude Code wrapper for Z.AI GLM API
#
# This script provides a separate command to use Claude Code with Z.AI GLM API,
# while keeping the original 'claude' command untouched.
#
# Usage:
#   claude-glm [claude arguments...]
#
# Examples:
#   claude-glm "explain this code"
#   claude-glm --version
#
# Configuration:
#   Set GLM_API_KEY in ~/.env
#   Get your API key from: https://api.z.ai
#
# Models:
#   - glm-5.2[1m]: Used for Opus and Sonnet tier (1M context)
#   - glm-4.5-air: Used for Haiku tier (fast)

set -euo pipefail

# Load environment variables from ~/.env
if [[ -f "$HOME/.env" ]]; then
  # Export GLM_API_KEY if it's defined in .env
  source "$HOME/.env"
fi

# Verify API key is set
if [[ -z "${GLM_API_KEY:-}" ]]; then
  echo "Error: GLM_API_KEY is not set" >&2
  echo "" >&2
  echo "Please set your GLM API key in ~/.env:" >&2
  echo "  export GLM_API_KEY=\"your-api-key-here\"" >&2
  echo "" >&2
  echo "Get your API key from: https://api.z.ai" >&2
  exit 1
fi

# Set Z.AI GLM API endpoint
export ANTHROPIC_BASE_URL="https://api.z.ai/api/anthropic"
export ANTHROPIC_AUTH_TOKEN="$GLM_API_KEY"

# Set longer timeout for GLM API (3000000 ms = 50 minutes)
export API_TIMEOUT_MS="3000000"

# Configure model mappings
# glm-5.2[1m] for Opus and Sonnet tier, glm-4.5-air for Haiku tier
export ANTHROPIC_DEFAULT_OPUS_MODEL="glm-5.2[1m]"
export ANTHROPIC_DEFAULT_SONNET_MODEL="glm-5.2[1m]"
export ANTHROPIC_DEFAULT_HAIKU_MODEL="glm-4.5-air"
export CLAUDE_CODE_AUTO_COMPACT_WINDOW="1000000"

# Mark that we're using GLM mode for statusline display
# CLAUDE_PROXY_MODEL is resolved dynamically by the statusline script
export CLAUDE_PROXY_MODE="glm"

# Rename tmux window for visual distinction from native claude
if [[ -n "${TMUX:-}" ]]; then
  tmux rename-window "claude-glm"
fi

# Background: periodically fetch GLM quota and cache it for statusline display
(
  while true; do
    response=$(curl -sf -H "Authorization: Bearer $GLM_API_KEY" \
      "https://api.z.ai/api/monitor/usage/quota/limit" 2>/dev/null) || { sleep 60; continue; }
    now=$(date +%s)
    read -r tokens_pct tokens_reset_ms weekly_pct weekly_reset_ms <<< "$(echo "$response" | jq -r '
      [.data.limits[] | select(.type == "TOKENS_LIMIT" and .unit == 3)][0] as $t |
      [.data.limits[] | select(.type == "TOKENS_LIMIT" and .unit == 6)][0] as $w |
      "\($t.percentage // "") \($t.nextResetTime // "") \($w.percentage // "") \($w.nextResetTime // "")"
    ')"
    if [[ -n "$tokens_pct" && "$tokens_pct" != "null" && -n "$tokens_reset_ms" && "$tokens_reset_ms" != "null" ]]; then
      tokens_remaining=$((100 - tokens_pct))
      tokens_reset_at=$((tokens_reset_ms / 1000))
      weekly_remaining=0
      weekly_reset_at=0
      if [[ -n "$weekly_pct" && "$weekly_pct" != "null" && -n "$weekly_reset_ms" && "$weekly_reset_ms" != "null" ]]; then
        weekly_remaining=$((100 - weekly_pct))
        weekly_reset_at=$((weekly_reset_ms / 1000))
      fi
      printf '{"tokens_remaining":%d,"tokens_reset_at":%d,"weekly_remaining":%d,"weekly_reset_at":%d,"fetched_at":%d}\n' \
        "$tokens_remaining" "$tokens_reset_at" "$weekly_remaining" "$weekly_reset_at" "$now" > /tmp/glm-quota-cache.json
    fi
    sleep 60
  done
) > /dev/null 2>&1 &
QUOTA_PID=$!

cleanup() {
  kill "$QUOTA_PID" 2>/dev/null
  wait "$QUOTA_PID" 2>/dev/null
}
trap cleanup EXIT INT TERM

# Forward all arguments to claude
claude "$@"

#!/usr/bin/env bash
# Claude Code status line display
#
# This script generates the status line display for Claude Code,
# showing different information based on how Claude was launched:
# - Native Claude Code: shows "[Model] 📁 dir | 🌿 branch"
# - GLM mode: shows "[GLM model-name] 📁 dir | 🌿 branch"

# Format epoch seconds as countdown string: " (Xd Yh)" or " (Xh Ym)" or " (Ym)" or ""
format_countdown() {
  local remaining=$(( $1 - $(date +%s) ))
  if [ "$remaining" -gt 0 ]; then
    local d=$(( remaining / 86400 )) h=$(( (remaining % 86400) / 3600 )) m=$(( (remaining % 3600) / 60 ))
    if [ "$d" -gt 0 ]; then
      echo " (${d}d${h}h)"
    elif [ "$h" -gt 0 ]; then
      echo " (${h}h${m}m)"
    else
      echo " (${m}m)"
    fi
  fi
}

# Read JSON input from stdin
input=$(cat)

# Extract values using jq
MODEL_DISPLAY=$(echo "$input" | jq -r '.model.display_name')
CURRENT_DIR=$(echo "$input" | jq -r '.workspace.current_dir')
CONTEXT_USED=$(echo "$input" | jq -r '.context_window.used_percentage // "null"')
RATE_LIMIT_USED=$(echo "$input" | jq -r '.rate_limits.five_hour.used_percentage | if . then floor | tostring else empty end')
RATE_LIMIT_RESETS_AT=$(echo "$input" | jq -r '.rate_limits.five_hour.resets_at // empty')

# Initialize rate limit display
RATE_LIMIT_DISPLAY=""

# Determine display prefix based on mode
if [ "$CLAUDE_PROXY_MODE" = "glm" ]; then
  # GLM mode: use display_name directly if it's a GLM model name,
  # otherwise map Anthropic tier names (opus/sonnet/haiku) to ANTHROPIC_DEFAULT_* env vars
  MODEL_LOWER="${MODEL_DISPLAY,,}"
  if [[ $MODEL_LOWER == *glm* ]]; then
    PREFIX="GLM $MODEL_DISPLAY"
  elif [[ $MODEL_LOWER == *opus* ]]; then
    PREFIX="GLM ${ANTHROPIC_DEFAULT_OPUS_MODEL:-}"
  elif [[ $MODEL_LOWER == *sonnet* ]]; then
    PREFIX="GLM ${ANTHROPIC_DEFAULT_SONNET_MODEL:-}"
  elif [[ $MODEL_LOWER == *haiku* ]]; then
    PREFIX="GLM ${ANTHROPIC_DEFAULT_HAIKU_MODEL:-}"
  else
    PREFIX="GLM"
  fi
  # Read GLM quota cache for statusline display
  WEEKLY_DISPLAY=""
  if [ -f /tmp/glm-quota-cache.json ]; then
    read -r GLM_REMAINING GLM_RESET_AT WEEKLY_REMAINING WEEKLY_RESET_AT <<< "$(jq -r '"\(.tokens_remaining // "") \(.tokens_reset_at // "") \(.weekly_remaining // "") \(.weekly_reset_at // "")"' /tmp/glm-quota-cache.json)"
    if [ -n "$GLM_REMAINING" ] && [ "$GLM_REMAINING" != "null" ]; then
      GLM_TIME=$(format_countdown "${GLM_RESET_AT:-0}")
      RATE_LIMIT_DISPLAY=" | 🔋 ${GLM_REMAINING}%${GLM_TIME}"
    fi
    if [ -n "$WEEKLY_REMAINING" ] && [ "$WEEKLY_REMAINING" != "null" ]; then
      WEEKLY_TIME=$(format_countdown "${WEEKLY_RESET_AT:-0}")
      WEEKLY_DISPLAY=" | 📊 ${WEEKLY_REMAINING}%${WEEKLY_TIME}"
    fi
  fi
else
  PREFIX="$MODEL_DISPLAY"
fi

# Show git branch if in a git repo
GIT_BRANCH=""
if git rev-parse --git-dir > /dev/null 2>&1; then
    BRANCH=$(git branch --show-current 2>/dev/null)
    if [ -n "$BRANCH" ]; then
        GIT_BRANCH=" | 🌿 $BRANCH"
    fi
fi

# Show context usage if available
CONTEXT_DISPLAY=""
if [ "$CONTEXT_USED" != "null" ] && [ -n "$CONTEXT_USED" ]; then
    CONTEXT_DISPLAY=" | 🧠 ${CONTEXT_USED}%"
fi

# Show rate limit usage and reset time if available (native mode)
if [ -n "$RATE_LIMIT_USED" ]; then
    RATE_LIMIT_TIME=$(format_countdown "${RATE_LIMIT_RESETS_AT:-0}")
    RATE_LIMIT_REMAINING=$(( 100 - RATE_LIMIT_USED ))
    RATE_LIMIT_DISPLAY=" | 🔋 ${RATE_LIMIT_REMAINING}%${RATE_LIMIT_TIME}"
fi

# Output the status line
echo "[$PREFIX] 📁 ${CURRENT_DIR##*/}$GIT_BRANCH$CONTEXT_DISPLAY$RATE_LIMIT_DISPLAY$WEEKLY_DISPLAY"

# Environment Variables Template
# Copy this file to ~/.env and fill in your actual values
#
# Usage:
#   cp ~/dotfiles/env.example ~/.env
#   nano ~/.env  # Edit with your actual credentials
#
# Security Note:
#   - ~/.env is NOT tracked by git (loaded by .bashrc)
#   - Never commit real credentials to version control
#   - Keep this file updated when adding new variables

# ====================
# Z.AI GLM API
# ====================

# GLM API Key from Z.AI Open Platform
# 取得位置: https://api.z.ai (API Keys management page)
# 使用方式: claude-glm 命令會自動使用此 API key
export GLM_API_KEY="your-api-key-here"

# ====================
# Windows PC Connection
# ====================

# Windows PC SSH credentials for remote operations
export WINDOWS_SSH_HOST="windows_pc"
export WINDOWS_SSH_PASSWORD="your_windows_ssh_password"

# ====================
# Samba / Network Share
# ====================

# Samba credentials (for mounting network share)
export SAMBA_SERVER="your_samba_server"
export SAMBA_USER="your_username"
export SAMBA_PASSWORD="your_samba_password"
export SAMBA_SHARE_ROOT="/path/to/share/root"

# ====================
# Native Build System (C++ Projects)
# ====================

# Cross-compiler SDK paths (請根據實際安裝路徑設定)
export IMX8_SDK_PATH="/path/to/imx8/sdk"
export AM625_SDK_PATH="/path/to/am625/sdk"

# ====================
# Custom Variables
# ====================

# Add your custom environment variables below
